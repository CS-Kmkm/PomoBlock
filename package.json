{
  "name": "pomoblock",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "PomoBlock core implementation from blocksched tasks",
  "scripts": {
    "init": "cargo run --manifest-path src-tauri/Cargo.toml --bin pomoblock-cli -- init",
    "status": "cargo run --manifest-path src-tauri/Cargo.toml --bin pomoblock-cli -- status",
    "doctor": "powershell -ExecutionPolicy Bypass -File scripts/doctor.ps1",
    "rust:check": "powershell -ExecutionPolicy Bypass -File scripts/rust-check.ps1",
    "build:windows": "powershell -ExecutionPolicy Bypass -File scripts/build-windows-installer.ps1",
    "build:windows:debug": "powershell -ExecutionPolicy Bypass -File scripts/build-windows-installer.ps1 -Debug",
    "build": "npm run build:ui",
    "build:ui": "tsc -p tsconfig.ui.json",
    "test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:watch": "node --test --watch",
    "typecheck": "tsc -p tsconfig.ui.json --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "typescript": "^5.8.2"
  }
}
