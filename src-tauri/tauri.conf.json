{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PomoBlock",
  "version": "0.1.0",
  "identifier": "com.pomoblock.app",
  "build": {
    "beforeDevCommand": "npm --prefix . run build:ui && node scripts/ui-dev-server.mjs",
    "devUrl": "http://127.0.0.1:1430",
    "beforeBuildCommand": "npm --prefix . run build",
    "frontendDist": "../src-ui"
  },
  "app": {
    "windows": [
      {
        "title": "PomoBlock",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ]
  }
}
